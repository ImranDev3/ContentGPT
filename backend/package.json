{
  "name": "contentgpt-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hono backend for ContentGPT — Manifest.build proxy + Wikipedia context",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.5",
    "dotenv": "^16.4.5",
    "hono": "^4.6.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
