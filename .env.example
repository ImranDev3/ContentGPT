# ContentGPT — server-side env vars
# Copy to `.env` (gitignored) and fill in real values.

# Manifest.build endpoint (OpenAI Responses API)
MANIFEST_BASE_URL=https://app.manifest.build/v1

# Get your key from https://app.manifest.build
MANIFEST_API_KEY=mnfst_replace_me_with_your_key

# Model id; "auto" lets the provider pick
MANIFEST_MODEL=auto

# Backend HTTP port
PORT=8787

# Optional: Google Programmable Search (better web results than DDG).
# Leave blank to fall back to DuckDuckGo Instant Answer (no key required).
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=
